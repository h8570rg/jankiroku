{
  "name": "jankiroku",
  "version": "0.2.0",
  "description": "麻雀成績管理アプリケーション",
  "type": "module",
  "config": {
    "supabase_project_ref": "ggkmppnjhrwzdsamzqbp"
  },
  "engines": {
    "node": "24.x"
  },
  "packageManager": "pnpm@11.15.1",
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3002",
    "lint": "biome lint --write",
    "format": "biome format --write",
    "check": "biome check --write",
    "type": "next typegen && tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "spell": "cspell . --gitignore",
    "eslint": "eslint .",
    "eslint:fix": "eslint . --fix",
    "supabase:login": "supabase login",
    "supabase:link": "supabase link --project-ref $npm_package_config_supabase_project_ref",
    "supabase:diff": "supabase db diff --linked -f local",
    "supabase:type": "supabase gen types typescript --linked > lib/database.types.ts"
  },
  "dependencies": {
    "@conform-to/react": "1.20.0",
    "@conform-to/zod": "1.20.0",
    "@heroui/react": "3.2.2",
    "@heroui/styles": "3.2.2",
    "@iconify/react": "6.0.2",
    "@supabase/ssr": "0.12.0",
    "@supabase/supabase-js": "2.110.7",
    "@tailwindcss/postcss": "4.3.3",
    "@vercel/analytics": "2.0.1",
    "@vercel/speed-insights": "2.0.0",
    "dayjs": "1.11.21",
    "lucide-react": "1.25.0",
    "motion": "12.42.2",
    "next": "16.2.10",
    "next-themes": "0.4.6",
    "postcss": "8.5.20",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "recharts": "3.9.2",
    "sharp": "0.35.3",
    "tailwindcss": "4.3.3",
    "use-debounce": "10.1.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@playwright/test": "1.61.1",
    "@types/node": "25.9.5",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/parser": "8.64.0",
    "cspell": "10.0.1",
    "eslint": "10.7.0",
    "eslint-plugin-better-tailwindcss": "4.7.0",
    "lefthook": "2.1.10",
    "supabase": "2.109.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  }
}
