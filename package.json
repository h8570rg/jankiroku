{
  "name": "jankiroku",
  "version": "0.2.0",
  "description": "麻雀成績管理アプリケーション",
  "type": "module",
  "config": {
    "supabase_project_ref": "ggkmppnjhrwzdsamzqbp"
  },
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3002",
    "lint": "biome lint --write",
    "format": "biome format --write",
    "check": "biome check --write",
    "type": "next typegen && tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "spell": "cspell . --gitignore",
    "eslint": "eslint .",
    "eslint:fix": "eslint . --fix",
    "supabase:login": "supabase login",
    "supabase:link": "supabase link --project-ref $npm_package_config_supabase_project_ref",
    "supabase:diff": "supabase db diff --linked -f local",
    "supabase:type": "supabase gen types typescript --linked > lib/database.types.ts"
  },
  "dependencies": {
    "@conform-to/react": "1.19.0",
    "@conform-to/zod": "1.19.0",
    "@heroui/react": "3.0.2",
    "@heroui/styles": "3.0.2",
    "@iconify/react": "6.0.2",
    "@supabase/ssr": "0.10.2",
    "@supabase/supabase-js": "2.104.0",
    "@tailwindcss/postcss": "4.2.3",
    "@vercel/analytics": "2.0.1",
    "@vercel/speed-insights": "2.0.0",
    "dayjs": "1.11.20",
    "lucide-react": "1.8.0",
    "motion": "12.38.0",
    "next": "16.2.4",
    "next-themes": "0.4.6",
    "postcss": "8.5.10",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "recharts": "3.8.1",
    "sharp": "0.34.5",
    "tailwindcss": "4.2.3",
    "use-debounce": "10.1.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@playwright/test": "1.59.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/parser": "8.59.0",
    "cspell": "10.0.0",
    "eslint": "10.2.1",
    "eslint-plugin-better-tailwindcss": "4.4.1",
    "lefthook": "2.1.6",
    "supabase": "2.93.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.0",
    "vitest": "4.1.5"
  }
}
